# Database (OBLIGATOIRE)
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/targetym

# Security (OBLIGATOIRE)
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_TOKEN_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development
DEBUG=true

# Super Admin Entreprise (OBLIGATOIRE — admin d'une entreprise cliente)
SUPER_ADMIN_EMAIL=admin2@targetym.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Tech Super Admin - Équipe Targetym (accès plateforme & centre d'aide)
TECH_SUPER_ADMIN_EMAIL=software@hcexecutive.net
TECH_SUPER_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_FOR_TECH_TEAM

# AI Chatbot - Anthropic Claude (Optionnel)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
# Modèles disponibles: claude-sonnet-4-6 (recommandé), claude-opus-4-6, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_CHAT_ENABLED=true

# Support Contact Info
SUPPORT_EMAIL=software@hcexecutive.net
SUPPORT_WHATSAPP=+221 77 397 80 44

# Email - Resend (OBLIGATOIRE pour l'envoi d'emails : invitations, alertes SOS, etc.)
# Obtenir une clé sur https://resend.com (gratuit jusqu'à 3000 emails/mois)
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=noreply@targetym.ai
APP_NAME=TARGETYM AI
APP_URL=https://targetym-dashboard.vercel.app
